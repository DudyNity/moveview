{
	"name": "foto-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "bun scripts/seed.ts",
		"postinstall": "node -e \"if(process.platform==='win32'){require('child_process').execSync('powershell -ExecutionPolicy Bypass -File scripts/unblock-native.ps1',{stdio:'inherit'})}\""
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.758.0",
		"@aws-sdk/s3-request-presigner": "^3.758.0",
		"@iconify/svelte": "^5.2.1",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@paralleldrive/cuid2": "^2.2.2",
		"archiver": "^7.0.1",
		"drizzle-orm": "^0.38.3",
		"lucia": "^3.2.2",
		"mercadopago": "^2.12.0",
		"oslo": "^1.2.1",
		"postgres": "^3.4.5",
		"resend": "^6.9.4",
		"sharp": "^0.33.5",
		"stripe": "^17.5.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.15.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/archiver": "^6.0.3",
		"@types/node": "^22.10.7",
		"autoprefixer": "^10.4.27",
		"drizzle-kit": "^0.30.4",
		"postcss": "^8.5.8",
		"svelte": "^5.19.0",
		"svelte-check": "^4.1.4",
		"tailwindcss": "3",
		"typescript": "^5.7.3",
		"vite": "^6.1.0"
	}
}
